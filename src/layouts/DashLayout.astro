---
// src/layouts/DashLayout.astro
import Layout from './Layout.astro';
import { createSupabaseServer } from '../lib/supabase';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title, activeNav } = Astro.props;
const { cookies } = Astro;
const supabase = createSupabaseServer(cookies);
const { data: { session } } = await supabase.auth.getSession();

if (!session) return Astro.redirect('/login');

// Get role from JWT user_metadata to avoid RLS recursion on users table
const jwtMeta = session.user.user_metadata || {};
const jwtRole = jwtMeta.role as string | undefined;

// Fall back to users table only if JWT metadata has no role yet
let role = jwtRole || 'taxpayer';
let fullName = jwtMeta.full_name || session.user.email || 'User';

if (!jwtRole) {
  const { data: userProfile } = await supabase
    .from('users')
    .select('role, full_name')
    .eq('id', session.user.id)
    .single();
  if (userProfile) {
    role = userProfile.role || 'taxpayer';
    fullName = userProfile.full_name || fullName;
  }
}

const initials = fullName.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
const currentPath = Astro.url.pathname;

const navItems = {
  taxpayer: [
    { href: '/dashboard', icon: '⊞', label: 'Dashboard' },
    { href: '/profile', icon: '◎', label: 'My Profile' },
    { href: '/returns', icon: '⊡', label: 'Tax Returns' },
    { href: '/payments', icon: '◈', label: 'Payments' },
    { href: '/notifications', icon: '◧', label: 'Notifications' },
  ],
  officer: [
    { href: '/dashboard', icon: '⊞', label: 'Dashboard' },
    { href: '/taxpayers', icon: '◉', label: 'Taxpayers' },
    { href: '/returns', icon: '⊡', label: 'Returns' },
    { href: '/payments', icon: '◈', label: 'Payments' },
    { href: '/audits', icon: '◨', label: 'Audits' },
    { href: '/compliance', icon: '◫', label: 'Compliance' },
    { href: '/reports', icon: '⊟', label: 'Reports' },
    { href: '/notifications', icon: '◧', label: 'Notifications' },
  ],
  admin: [
    { href: '/dashboard', icon: '⊞', label: 'Dashboard' },
    { href: '/taxpayers', icon: '◉', label: 'Taxpayers' },
    { href: '/returns', icon: '⊡', label: 'Returns' },
    { href: '/payments', icon: '◈', label: 'Payments' },
    { href: '/audits', icon: '◨', label: 'Audits' },
    { href: '/compliance', icon: '◫', label: 'Compliance' },
    { href: '/reports', icon: '⊟', label: 'Reports' },
    { href: '/users', icon: '◑', label: 'User Mgmt' },
    { href: '/logs', icon: '▣', label: 'Audit Logs' },
    { href: '/notifications', icon: '◧', label: 'Notifications' },
  ],
};

const items = navItems[role as keyof typeof navItems] || navItems.taxpayer;

// Unread notifications count — only for taxpayers (notifications use taxpayer_id)
let unreadCount = 0;
if (role === 'taxpayer') {
  const { data: tp } = await supabase
    .from('taxpayers').select('id').eq('user_id', session.user.id).single();
  if (tp?.id) {
    const { count } = await supabase
      .from('notifications')
      .select('*', { count: 'exact', head: true })
      .eq('taxpayer_id', tp.id)
      .eq('is_read', false);
    unreadCount = count || 0;
  }
}
---

<Layout title={title}>
  <div class="dash-shell">
    <!-- Sidebar -->
    <aside class="sidebar">
      <!-- Logo/Brand -->
      <div class="sidebar-brand">
        <div class="brand-emblem">
            <img src="https://th.bing.com/th/id/OIP.7t_c8akM3_MkVBsbc4cmfQHaD2?w=312&h=180&c=7&r=0&o=7&pid=1.7&rm=3" alt="MRA Logo" style="width: 100%; height: auto; border: 1px solid #fff; border-radius: 4px;" />
        </div>
        <div>
          <div class="brand-name">MRA</div>
          <div class="brand-sub">Tax System</div>
        </div>
      </div>

      <nav class="sidebar-nav">
        {items.map(item => {
          const active =
            activeNav === item.href ||
            currentPath === item.href ||
            (item.href !== '/dashboard' && currentPath.startsWith(item.href + '/'));
          return (
            <a href={item.href} class={`nav-item ${active ? 'active' : ''}`}>
              <span class="nav-icon">{item.icon}</span>
              <span class="nav-label">{item.label}</span>
              {item.href === '/notifications' && unreadCount > 0 && (
                <span class="nav-badge">{unreadCount}</span>
              )}
            </a>
          );
        })}
      </nav>

      <!-- User chip -->
      <div class="sidebar-user">
        <div class="user-avatar">{initials}</div>
        <div class="user-info">
          <div class="user-name">{fullName.split(' ')[0]}</div>
          <div class="user-role">{role.charAt(0).toUpperCase() + role.slice(1)}</div>
        </div>
        <form method="POST" action="/api/logout" style="margin-left: auto;">
          <button type="submit" class="logout-btn" title="Sign out">↩</button>
        </form>
      </div>
    </aside>

    <!-- Main area -->
    <main class="dash-main">
      <!-- Top bar -->
      <header class="topbar">
        <div class="topbar-left">
          {title && <h1 class="topbar-title">{title}</h1>}
        </div>
        <div class="topbar-right">
          <span class="topbar-date">{new Date().toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' })}</span>
        </div>
      </header>

      <!-- Page content -->
      <div class="dash-content">
        <slot />
      </div>
    </main>
  </div>

  <style>
    .dash-shell {
      display: flex;
      min-height: 100vh;
    }

    /* SIDEBAR */
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      background: var(--mra-green-dark);
      color: #fff;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
    }

    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.25rem 1rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .brand-emblem { font-size: 1.8rem; line-height: 1; }
    .brand-name { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; letter-spacing: 0.04em; }
    .brand-sub { font-size: 0.7rem; color: rgba(255,255,255,0.6); letter-spacing: 0.08em; text-transform: uppercase; }

    .flag-strip {
      display: flex;
      height: 3px;
    }
    .flag-strip span { flex: 1; }

    .sidebar-nav {
      flex: 1;
      padding: 0.75rem 0;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 1rem;
      color: rgba(255,255,255,0.75);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      transition: all 0.15s;
      position: relative;
      border-radius: 0;
    }
    .nav-item:hover { background: rgba(255,255,255,0.08); color: #fff; text-decoration: none; }
    .nav-item.active { background: rgba(255,255,255,0.12); color: #fff; border-left: 3px solid var(--mra-gold); }
    .nav-icon { font-size: 0.95rem; width: 1.2rem; text-align: center; flex-shrink: 0; }
    .nav-label { flex: 1; }
    .nav-badge { background: var(--mra-red); color: #fff; font-size: 0.68rem; font-weight: 700; padding: 0.15em 0.45em; border-radius: 999px; min-width: 18px; text-align: center; }

    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.9rem 1rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      background: rgba(0,0,0,0.15);
    }
    .user-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: var(--mra-gold);
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 700;
      flex-shrink: 0;
    }
    .user-name { font-size: 0.85rem; font-weight: 600; color: #fff; }
    .user-role { font-size: 0.7rem; color: rgba(255,255,255,0.55); text-transform: capitalize; }
    .logout-btn {
      background: none; border: 1px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.7);
      border-radius: 6px; padding: 0.3rem 0.5rem; cursor: pointer; font-size: 0.9rem;
      transition: all 0.15s;
    }
    .logout-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

    /* MAIN */
    .dash-main {
      margin-left: 220px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .topbar {
      background: #fff;
      border-bottom: 1px solid var(--mra-gray-200);
      padding: 0.85rem 1.75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
      min-height: 56px;
    }
    .topbar-title { font-size: 1.15rem; font-family: var(--font-serif); margin: 0; color: var(--mra-gray-900); }
    .topbar-sub { font-size: 0.78rem; color: var(--mra-gray-500); margin: 0.1rem 0 0; }
    .topbar-date { font-size: 0.8rem; color: var(--mra-gray-500); font-family: var(--font-mono); }

    .dash-content {
      padding: 1.5rem 1.75rem;
      flex: 1;
    }

    @media (max-width: 900px) {
      .sidebar { width: 56px; }
      .brand-name, .brand-sub, .nav-label, .user-info { display: none; }
      .sidebar-brand { justify-content: center; padding: 1rem 0.5rem; gap: 0; }
      .nav-item { justify-content: center; padding: 0.75rem; }
      .nav-icon { width: auto; }
      .sidebar-user { justify-content: center; }
      .dash-main { margin-left: 56px; }
    }
  </style>
</Layout>