---
import DashLayout from '../../layouts/DashLayout.astro';
import { createSupabaseServer, formatMWK, formatDate } from '../../lib/supabase';

const supabase = createSupabaseServer(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { id } = Astro.params;
const { data: userProfile } = await supabase
  .from('users').select('*').eq('id', session.user.id).single();
const role = userProfile?.role || 'taxpayer';

const { data: audit, error } = await supabase
  .from('audits')
  .select('*, taxpayers(id, tin, name, email, phone, taxpayer_type, address), users!audits_assigned_officer_id_fkey(full_name, email)')
  .eq('id', id)
  .single();

if (error || !audit) return Astro.redirect('/audits');

const isNew  = Astro.url.searchParams.get('new') === '1';
let successMessage = '';
let errorMessage   = '';

if (Astro.request.method === 'POST' && role !== 'taxpayer') {
  const form   = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  const updates: Record<string, any> = {};

  if (action === 'start')    updates.status = 'in_progress';
  if (action === 'findings') updates.status = 'findings_issued';
  if (action === 'close')  { updates.status = 'closed'; updates.completion_date = new Date().toISOString().split('T')[0]; }
  if (action === 'notify')   updates.taxpayer_notified_at = new Date().toISOString();

  if (action === 'save_findings') {
    updates.findings          = form.get('findings')?.toString().trim() || '';
    updates.additional_assessment = parseFloat(form.get('additional_assessment')?.toString() || '0') || 0;
    updates.recommendations   = form.get('recommendations')?.toString().trim() || '';
  }

  if (Object.keys(updates).length > 0) {
    const { error: e } = await supabase.from('audits').update(updates).eq('id', id);
    if (e) errorMessage = e.message;
    else   return Astro.redirect(`/audits/${id}?saved=${action}`);
  }
}

const saved = Astro.url.searchParams.get('saved');

const statusBadge: Record<string, string> = {
  initiated:       'badge-blue',
  in_progress:     'badge-yellow',
  findings_issued: 'badge-orange',
  closed:          'badge-green',
  appealed:        'badge-red',
};
const riskBadge: Record<string, string> = {
  low: 'badge-green', medium: 'badge-yellow', high: 'badge-red',
};
const typeLabel: Record<string, string> = {
  desk: 'Desk Audit', field: 'Field Audit', special: 'Special Audit',
};
const savedMsgs: Record<string, { cls: string; msg: string }> = {
  start:         { cls: 'alert-info',    msg: '🔍 Audit is now in progress.' },
  findings:      { cls: 'alert-warning', msg: '📋 Findings issued to taxpayer.' },
  close:         { cls: 'alert-success', msg: '✓ Audit case closed.' },
  notify:        { cls: 'alert-info',    msg: '📧 Taxpayer notification recorded.' },
  save_findings: { cls: 'alert-success', msg: '✓ Findings saved successfully.' },
};
---

<DashLayout title={`Audit ${audit.audit_reference}`} activeNav="/audits">
  <div class="page-header">
    <div>
      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
        <h1 class="page-title" style="margin:0;">{audit.audit_reference}</h1>
        <span class={`badge ${statusBadge[audit.status] || 'badge-gray'}`} style="font-size:0.8rem; padding:0.3em 0.85em;">
          {audit.status.replace(/_/g, ' ')}
        </span>
        {audit.risk_level && (
          <span class={`badge ${riskBadge[audit.risk_level]}`} style="font-size:0.78rem;">
            {audit.risk_level} risk
          </span>
        )}
      </div>
      <p class="page-subtitle">{typeLabel[audit.audit_type]} · {formatDate(audit.period_from)} – {formatDate(audit.period_to)}</p>
    </div>
    <a href="/audits" class="btn btn-ghost">← All Audits</a>
  </div>

  {isNew && <div class="alert alert-success" style="margin-bottom:1.25rem;">✓ Audit case <strong>{audit.audit_reference}</strong> initiated successfully.</div>}
  {saved && savedMsgs[saved] && <div class={`alert ${savedMsgs[saved].cls}`} style="margin-bottom:1.25rem;">{savedMsgs[saved].msg}</div>}
  {errorMessage && <div class="alert alert-danger" style="margin-bottom:1rem;">{errorMessage}</div>}

  <div class="detail-layout">
    <div>
      <!-- Case details -->
      <div class="card">
        <h2 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--mra-gray-500); margin-bottom:1rem;">Case Details</h2>
        <div class="detail-row"><span class="detail-label">Case Reference</span><span class="detail-value mono">{audit.audit_reference}</span></div>
        <div class="detail-row"><span class="detail-label">Audit Type</span><span class="detail-value">{typeLabel[audit.audit_type]}</span></div>
        <div class="detail-row"><span class="detail-label">Audit Period</span><span class="detail-value">{formatDate(audit.period_from)} – {formatDate(audit.period_to)}</span></div>
        <div class="detail-row"><span class="detail-label">Start Date</span><span class="detail-value">{formatDate(audit.start_date)}</span></div>
        <div class="detail-row"><span class="detail-label">Completion Date</span><span class="detail-value">{audit.completion_date ? formatDate(audit.completion_date) : '—'}</span></div>
        <div class="detail-row"><span class="detail-label">Assigned Officer</span><span class="detail-value">{audit.users?.full_name || '—'}</span></div>
        <div class="detail-row"><span class="detail-label">Taxpayer Notified</span><span class="detail-value">{audit.taxpayer_notified_at ? formatDate(audit.taxpayer_notified_at) : 'Not yet'}</span></div>

        {audit.reason && (
          <div style="margin-top:1rem; padding-top:1rem; border-top:1px solid var(--mra-gray-200);">
            <div class="detail-label" style="margin-bottom:0.4rem;">Reason for Audit</div>
            <p style="font-size:0.88rem; color:var(--mra-gray-700); margin:0; line-height:1.5;">{audit.reason}</p>
          </div>
        )}
      </div>

      <!-- Findings -->
      {(audit.status === 'findings_issued' || audit.status === 'closed' || audit.findings) && (
        <div class="card" style="margin-top:1.25rem;">
          <h2 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--mra-gray-500); margin-bottom:1rem;">Audit Findings</h2>
          {audit.additional_assessment > 0 && (
            <div class="assessment-banner">
              <span>Additional Assessment</span>
              <span class="mono" style="font-size:1.1rem; font-weight:700;">{formatMWK(audit.additional_assessment)}</span>
            </div>
          )}
          {audit.findings && (
            <div style="margin-bottom:1rem;">
              <div class="detail-label" style="margin-bottom:0.4rem;">Findings</div>
              <p style="font-size:0.88rem; color:var(--mra-gray-700); line-height:1.6; margin:0;">{audit.findings}</p>
            </div>
          )}
          {audit.recommendations && (
            <div>
              <div class="detail-label" style="margin-bottom:0.4rem;">Recommendations</div>
              <p style="font-size:0.88rem; color:var(--mra-gray-700); line-height:1.6; margin:0;">{audit.recommendations}</p>
            </div>
          )}
        </div>
      )}

      <!-- Officer: Save findings form -->
      {role !== 'taxpayer' && audit.status !== 'closed' && (
        <div class="card" style="margin-top:1.25rem;">
          <h2 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--mra-gray-500); margin-bottom:1rem;">Record Findings</h2>
          <form method="POST">
            <input type="hidden" name="_action" value="save_findings" />
            <div class="form-group">
              <label class="form-label" for="findings">Findings</label>
              <textarea id="findings" name="findings" class="form-control" rows="4"
                placeholder="Document audit findings...">{audit.findings || ''}</textarea>
            </div>
            <div class="form-group">
              <label class="form-label" for="additional_assessment">Additional Assessment (MWK)</label>
              <input id="additional_assessment" type="number" name="additional_assessment"
                class="form-control" value={audit.additional_assessment || 0} min="0" step="0.01" />
              <p class="form-hint">Additional tax liability identified during audit.</p>
            </div>
            <div class="form-group">
              <label class="form-label" for="recommendations">Recommendations</label>
              <textarea id="recommendations" name="recommendations" class="form-control" rows="3"
                placeholder="Recommendations for the taxpayer...">{audit.recommendations || ''}</textarea>
            </div>
            <button type="submit" class="btn btn-primary">Save Findings</button>
          </form>
        </div>
      )}
    </div>

    <!-- Sidebar -->
    <div>
      <!-- Taxpayer card -->
      <div class="card">
        <h3 style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--mra-gray-500); margin-bottom:0.85rem;">Taxpayer</h3>
        <div class="mono" style="font-size:1rem; font-weight:700; color:var(--mra-green); margin-bottom:0.2rem;">{audit.taxpayers?.tin}</div>
        <div style="font-size:0.95rem; font-weight:600; color:var(--mra-gray-900); margin-bottom:0.75rem;">{audit.taxpayers?.name}</div>
        <div class="detail-row"><span class="detail-label">Type</span><span class="detail-value" style="text-transform:capitalize;">{audit.taxpayers?.taxpayer_type}</span></div>
        <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value" style="font-size:0.8rem;">{audit.taxpayers?.email || '—'}</span></div>
        <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">{audit.taxpayers?.phone || '—'}</span></div>
        <div class="detail-row"><span class="detail-label">Address</span><span class="detail-value" style="max-width:120px; text-align:right; font-size:0.8rem;">{audit.taxpayers?.address || '—'}</span></div>
      </div>

      <!-- Officer actions -->
      {role !== 'taxpayer' && (
        <div class="card" style="margin-top:1rem;">
          <h3 style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--mra-gray-500); margin-bottom:0.85rem;">Case Actions</h3>
          <div style="display:flex; flex-direction:column; gap:0.5rem;">
            {audit.status === 'initiated' && (
              <form method="POST">
                <input type="hidden" name="_action" value="start" />
                <button type="submit" class="btn btn-primary btn-sm w-full">▶ Start Audit</button>
              </form>
            )}
            {audit.status === 'in_progress' && (
              <form method="POST">
                <input type="hidden" name="_action" value="findings" />
                <button type="submit" class="btn btn-gold btn-sm w-full">📋 Issue Findings</button>
              </form>
            )}
            {(audit.status === 'findings_issued' || audit.status === 'in_progress') && (
              <form method="POST">
                <input type="hidden" name="_action" value="close" />
                <button type="submit" class="btn btn-secondary btn-sm w-full"
                  onclick="return confirm('Close this audit case?')">✓ Close Case</button>
              </form>
            )}
            {!audit.taxpayer_notified_at && (
              <form method="POST">
                <input type="hidden" name="_action" value="notify" />
                <button type="submit" class="btn btn-ghost btn-sm w-full">📧 Mark as Notified</button>
              </form>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</DashLayout>

<style>
  .detail-layout { display:grid; grid-template-columns:1fr 260px; gap:1.5rem; align-items:start; }
  @media (max-width:900px) { .detail-layout { grid-template-columns:1fr; } }
  .assessment-banner {
    display:flex; justify-content:space-between; align-items:center;
    background:var(--mra-red-light); border-left:4px solid var(--mra-red);
    border-radius:0 var(--radius) var(--radius) 0;
    padding:0.85rem 1rem; margin-bottom:1rem;
    font-size:0.88rem; font-weight:600; color:var(--mra-red);
  }
</style>