---
import Layout from '../layouts/Layout.astro';
import { createSupabaseServer } from '../lib/supabase';

const supabase = createSupabaseServer(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (session) return Astro.redirect('/dashboard');

let errorMessage = '';
let successMessage = '';

if (Astro.request.method === 'POST') {
  const contentType = Astro.request.headers.get('content-type') || '';

  if (contentType.includes('application/x-www-form-urlencoded') ||
      contentType.includes('multipart/form-data')) {

    const form = await Astro.request.formData();

    const email = form.get('email')?.toString() || '';
    const password = form.get('password')?.toString() || '';
    const confirmPassword = form.get('confirm_password')?.toString() || '';
    const fullName = form.get('full_name')?.toString() || '';

    // validation logic...
  } else {
    errorMessage = 'Invalid form submission.';
  }
}
---

<Layout title="Register">
  <div class="auth-page">
    <div class="auth-banner">
      <div class="banner-content">
        <div class="banner-emblem">
          <img src="https://www.mra.mw/images/MRA%20AT%2025%20LOGO%20FINAL-01.png" alt="MRA Emblem" style="width: 100%; height: auto;" />
        </div>
        <h1>Malawi Revenue Authority</h1>
        <p>Taxpayer Registration Portal</p>
        <div class="banner-divider"></div>
        <!-- <ul class="feature-list">
          <li>✓ Submit tax returns online</li>
          <li>✓ Track payment history</li>
          <li>✓ Receive compliance notices</li>
          <li>✓ View audit status</li>
        </ul> -->
      </div>
    </div>

    <div class="auth-panel">
      <div class="auth-box">
        <div class="auth-header">
          <h2>Create Account</h2>
          <p>Register as an MRA taxpayer</p>
        </div>

        {successMessage && (
          <div class="alert alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            {successMessage}
          </div>
        )}
        {errorMessage && (
          <div class="alert alert-error">
            {/* <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> */}
            {errorMessage}
          </div>
        )}

        {!successMessage && (
          <form method="POST" class="auth-form">
            <div class="form-group">
              <label class="form-label">Full Name</label>
              <input class="form-input" type="text" name="full_name" placeholder="Name" required />
            </div>
            <div class="form-group">
              <label class="form-label">Email Address</label>
              <input class="form-input" type="email" name="email" placeholder="Email" required />
            </div>
            <div class="form-group">
              <label class="form-label">Password</label>
              <input class="form-input" type="password" name="password" placeholder="Password- 8+ chars" minlength="8" required />
            </div>
            <div class="form-group">
              <label class="form-label">Confirm Password</label>
              <input class="form-input" type="password" name="confirm_password" placeholder="Verify password" required />
            </div>
            <p class="notice">After registration, complete your taxpayer profile to receive your TIN.</p>
            <button type="submit" class="btn btn-primary btn-full">Create Account →</button>
          </form>
        )}

        <div class="auth-footer">
          <p>Already registered? <a href="/login">Sign in</a></p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
.auth-page { display: flex; min-height: 100vh; }
.auth-banner { width: 45%; background: var(--mra-green-dark); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.auth-banner::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.02) 40px, rgba(255,255,255,0.02) 80px); }
.banner-content { text-align: center; color: white; position: relative; z-index: 1; padding: 40px; }
.banner-flag { display: flex; gap: 6px; justify-content: center; margin-bottom: 24px; }
.flag-bar { height: 32px; width: 10px; border-radius: 2px; }
.bar-black { background: #222; }
.bar-red { background: #CE1126; }
.bar-white { background: rgba(255,255,255,0.9); }
.bar-green { background: #009A44; }
.banner-emblem { font-size: 60px; margin-bottom: 16px; display: block; }
.banner-content h1 { font-family: var(--font-serif); font-size: 28px; margin-bottom: 8px; color: #FFD700; }
.banner-content p { font-size: 15px; color: rgba(255,255,255,0.7); margin-bottom: 24px; }
.banner-divider { width: 40px; height: 2px; background: rgba(255,215,0,0.5); margin: 0 auto 20px; }
.feature-list { list-style: none; text-align: left; display: inline-block; }
.feature-list li { font-size: 14px; color: rgba(255,255,255,0.8); padding: 4px 0; }
.auth-panel { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px; background: var(--mra-gray-50); }
.auth-box { width: 100%; max-width: 420px; }
.auth-header { margin-bottom: 28px; }
.auth-header h2 { font-family: var(--font-serif); font-size: 26px; color: var(--mra-black); margin-bottom: 6px; }
.auth-header p { color: var(--mra-gray-400); font-size: 15px; }
.notice { font-size: 12px; color: var(--mra-gray-400); margin-bottom: 12px; padding: 10px 12px; background: var(--mra-gray-50); border-left: 3px solid var(--mra-gold); }
.auth-form .btn-full { width: 100%; justify-content: center; padding: 13px; font-size: 15px; margin-top: 4px; }
.auth-footer { margin-top: 24px; text-align: center; font-size: 14px; color: var(--mra-gray-400); }
.auth-footer a { color: var(--mra-green); font-weight: 600; }
@media (max-width: 768px) { .auth-banner { display: none; } .auth-panel { padding: 24px; } }
</style>